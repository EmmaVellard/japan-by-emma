# This project uses pnpm. Keep npm's local lockfile out of the repository.
package-lock.json
src/assets/images/about/emma-portrait1.jpeg

# Keep unpublished lens photographs local. Add an explicit exception when a
# photograph is ready to appear on the public website.
src/assets/images/lens/*
!src/assets/images/lens/.gitkeep

# Original photographs are local inputs only. Only processed web copies belong
# in src/assets/images/generated/.
photos/originals/**
!photos/originals/.gitkeep
