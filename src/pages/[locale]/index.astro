---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import GuideCard from '../../components/GuideCard.astro';
import ItineraryCard from '../../components/ItineraryCard.astro';
import DestinationCard from '../../components/DestinationCard.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';
import homepageImage from '../../assets/images/generated/homepage/home-hero.jpg';
import galleryTokyoImage from '../../assets/images/generated/homepage/gallery-tokyo.jpg';
import tokyoImage from '../../assets/images/generated/tokyo/tokyo-hero.jpg';
import kyotoImage from '../../assets/images/generated/kyoto/kyoto-hero.jpg';
import osakaImage from '../../assets/images/generated/osaka/osaka-hero.jpg';
import {
  dictionaries,
  isLocale,
  localisedPath,
  locales,
  otherLocale,
  type Locale,
  withBase,
} from '../../i18n/utils';
import { maps } from '../../data/maps';
import { lensImages } from '../../data/lens';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}
const rawLocale = Astro.params.locale;
if (!isLocale(rawLocale)) throw new Error('Unsupported locale');
const locale: Locale = rawLocale;
const t = dictionaries[locale];
const [allGuides, allItineraries, allDestinations] = await Promise.all([
  getCollection('guide'),
  getCollection('itineraries'),
  getCollection('destinations'),
]);
const guides = allGuides
  .filter((entry) => entry.data.locale === locale && entry.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
const itineraries = allItineraries
  .filter((entry) => entry.data.locale === locale)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const destinations = allDestinations
  .filter((entry) => entry.data.locale === locale)
  .sort((a, b) => a.data.order - b.data.order);
const destinationImages = {
  Tokyo: tokyoImage,
  Kyoto: kyotoImage,
  Osaka: osakaImage,
};
const alternatePath = localisedPath(otherLocale(locale));
const alt =
  locale === 'en'
    ? 'A personal photograph from my travels in Japan'
    : 'Une photographie personnelle prise pendant mes voyages au Japon';
const homepageLensImages =
  lensImages.length > 0
    ? lensImages.slice(0, 3)
    : [galleryTokyoImage, kyotoImage, osakaImage];
---

<BaseLayout
  {locale}
  title="Japan by Emma"
  description={t.home.subtitle}
  {alternatePath}
>
  <HeroSection
    eyebrow={t.home.eyebrow}
    title={t.home.title}
    subtitle={t.home.subtitle}
    image={homepageImage}
    {alt}
    primaryHref={withBase(localisedPath(locale, 'guide'))}
    primaryLabel={t.actions.startPlanning}
    secondaryHref={withBase(localisedPath(locale, 'maps'))}
    secondaryLabel={t.actions.exploreMap}
  />

  <section
    class="section-space shell grid gap-10 md:grid-cols-[0.8fr_1.2fr] md:items-start"
  >
    <p class="eyebrow">
      {
        locale === 'en'
          ? 'From my travel notes'
          : 'À partir de mes carnets de voyage'
      }
    </p>
    <div>
      <h2 class="section-title">{t.home.introTitle}</h2><p
        class="mt-6 max-w-2xl text-lg leading-8 text-ink-soft"
      >
        {t.home.intro}
      </p>
    </div>
  </section>

  <section class="border-y border-ink/10 bg-paper-deep/55">
    <div class="section-space shell">
      <SectionHeader title={t.home.guideTitle} intro={t.home.guideIntro} />
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          guides.map((entry, index) => (
            <GuideCard
              title={entry.data.title}
              description={entry.data.description}
              href={`${localisedPath(locale, 'guide')}#${entry.data.translationKey}`}
              number={String(index + 1).padStart(2, '0')}
            />
          ))
        }
      </div>
      <a
        class="button-secondary mt-8"
        href={withBase(localisedPath(locale, 'guide'))}>{t.actions.seeAll} →</a
      >
    </div>
  </section>

  <section class="section-space shell">
    <SectionHeader
      title={t.home.itineraryTitle}
      intro={locale === 'en'
        ? 'Choose a route, then adjust it to your pace and airport.'
        : 'Choisissez un parcours, puis adaptez-le à votre rythme et à votre aéroport.'}
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        itineraries.map((entry, index) => (
          <ItineraryCard
            title={entry.data.title}
            description={entry.data.description}
            href={localisedPath(locale, 'itineraries', entry.data.slug)}
            days={entry.data.days}
            dayLabel={t.labels.days}
            destinations={entry.data.destinations.slice(0, 4)}
            featured={index === 0}
          />
        ))
      }
    </div>
    <a
      class="button-secondary mt-8"
      href={withBase(localisedPath(locale, 'itineraries'))}
      >{t.actions.seeAll} →</a
    >
  </section>

  <section class="border-y border-ink/10 bg-sage-pale/65">
    <div class="section-space shell">
      <SectionHeader
        title={t.home.destinationTitle}
        intro={t.home.destinationIntro}
      />
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          destinations.map((entry) => (
            <DestinationCard
              title={entry.data.title}
              description={entry.data.description}
              href={localisedPath(locale, 'destinations', entry.data.slug)}
              image={
                destinationImages[
                  entry.data.title as keyof typeof destinationImages
                ]
              }
              alt={alt}
              meta={entry.data.recommendedDuration}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-space shell grid gap-8 lg:grid-cols-2">
    <div class="editorial-card editorial-card-dark p-8 sm:p-10">
      <p class="eyebrow text-[#f2a08b]">Mapstr</p><h2 class="mt-6 text-4xl">
        {t.home.recommendationsTitle}
      </h2><p class="mt-5 max-w-xl leading-7 text-paper/70">
        {t.home.recommendationsText}
      </p><a
        class="button-primary mt-8 bg-[#a94735]"
        href={maps.mapstr}
        rel="external noreferrer"
        target="_blank">{t.actions.openMap} ↗</a
      >
    </div>
    <div class="editorial-card p-8 sm:p-10">
      <p class="eyebrow">Google My Maps</p><h2 class="mt-6 text-4xl">
        {t.actions.exploreMap}
      </h2><p class="mt-5 max-w-xl leading-7 text-ink-soft">
        {
          locale === 'en'
            ? 'Restaurants, cafes, hotels, museums, parks and places I am considering across Japan.'
            : 'Restaurants, cafés, hôtels, musées, parcs et lieux que j’envisage dans tout le Japon.'
        }
      </p><a class="button-secondary mt-8" href={maps.googleMyMaps}
        >{t.actions.openMap} ↗</a
      >
    </div>
  </section>

  <section class="border-y border-ink/10 bg-paper-deep/55">
    <div class="section-space shell">
      <SectionHeader
        title={t.home.photographyTitle}
        intro={t.home.photographyText}
        singleLine
      />
      <div class="mt-10">
        <PhotoGallery
          photos={homepageLensImages.map((image) => ({ image, alt }))}
          showCredit
        />
      </div>
      <a
        class="button-secondary mt-8"
        href={withBase(localisedPath(locale, 'lens'))}
      >
        {t.actions.viewGallery} →
      </a>
    </div>
  </section>
</BaseLayout>
