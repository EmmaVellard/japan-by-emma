---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ContentLayout from '../../../layouts/ContentLayout.astro';
import DayTimeline from '../../../components/DayTimeline.astro';
import InfoBox from '../../../components/InfoBox.astro';
import WarningBox from '../../../components/WarningBox.astro';
import PhotoGallery from '../../../components/PhotoGallery.astro';
import DistrictGuide from '../../../components/DistrictGuide.astro';
import DestinationPhotoGallery from '../../../components/DestinationPhotoGallery.astro';
import {
  dictionaries,
  localisedPath,
  otherLocale,
  sectionSlugs,
  type Locale,
  withBase,
} from '../../../i18n/utils';
import { maps } from '../../../data/maps';
import { cityDistricts } from '../../../data/city-districts';
import { getDestinationPhotos } from '../../../data/destination-photos';
import { destinationPageSlugs } from '../../../data/destinations';

type PageKind = 'itineraries' | 'destinations';
type PageEntry = CollectionEntry<PageKind>;
interface PageNavItem {
  title: string;
  slug: string;
}
interface PageProps {
  locale: Locale;
  kind: PageKind;
  entry: PageEntry;
  translation?: PageEntry;
  previous?: PageNavItem;
  next?: PageNavItem;
}

export async function getStaticPaths() {
  const kinds: PageKind[] = ['itineraries', 'destinations'];
  const pages = await Promise.all(
    kinds.map(async (kind) => ({ kind, entries: await getCollection(kind) })),
  );
  return pages.flatMap(({ kind, entries }) =>
    entries.map((entry) => {
      const locale = entry.data.locale as Locale;
      const translation = entries.find(
        (candidate) =>
          candidate.data.translationKey === entry.data.translationKey &&
          candidate.data.locale !== locale,
      );
      const siblings = entries
        .filter((candidate) => candidate.data.locale === locale)
        .sort((a, b) => a.data.order - b.data.order);
      const siblingIndex = siblings.findIndex(
        (candidate) => candidate.id === entry.id,
      );
      const previousEntry =
        kind === 'destinations' && siblings.length > 1
          ? siblings[(siblingIndex - 1 + siblings.length) % siblings.length]
          : siblingIndex > 0
            ? siblings[siblingIndex - 1]
            : undefined;
      const nextEntry =
        kind === 'destinations' && siblings.length > 1
          ? siblings[(siblingIndex + 1) % siblings.length]
          : siblingIndex >= 0 && siblingIndex < siblings.length - 1
            ? siblings[siblingIndex + 1]
            : undefined;
      const previous = previousEntry
        ? {
            title: previousEntry.data.title,
            slug: previousEntry.data.slug,
          }
        : undefined;
      const next = nextEntry
        ? { title: nextEntry.data.title, slug: nextEntry.data.slug }
        : undefined;
      return {
        params: {
          locale,
          section: sectionSlugs[kind][locale],
          slug: entry.data.slug,
        },
        props: { locale, kind, entry, translation, previous, next },
      };
    }),
  );
}

const { locale, kind, entry, translation, previous, next } =
  Astro.props as PageProps;
const { Content, headings } = await render(entry);
const t = dictionaries[locale];
const targetLocale = otherLocale(locale);
const alternatePath = translation
  ? localisedPath(targetLocale, kind, translation.data.slug)
  : localisedPath(targetLocale);
const sectionTitle =
  kind === 'itineraries' ? t.pages.itineraryTitle : t.pages.destinationTitle;
const breadcrumbs = [
  { label: 'Japan by Emma', href: localisedPath(locale) },
  { label: sectionTitle, href: localisedPath(locale, kind) },
  { label: entry.data.title },
];
const districts =
  kind === 'destinations' ? (cityDistricts[locale][entry.data.slug] ?? []) : [];
const destinationPhotos =
  kind === 'destinations' ? getDestinationPhotos(entry.data.slug) : [];
const destinationHtml =
  kind === 'destinations' && districts.length > 0
    ? entry.rendered?.html
    : undefined;
const thirdDestinationHeadingIndex = destinationHtml
  ? [...destinationHtml.matchAll(/<h2\b/g)][2]?.index
  : undefined;
const destinationOpeningHtml =
  destinationHtml && typeof thirdDestinationHeadingIndex === 'number'
    ? destinationHtml.slice(0, thirdDestinationHeadingIndex)
    : undefined;
const destinationRemainingHtml =
  destinationHtml && typeof thirdDestinationHeadingIndex === 'number'
    ? destinationHtml.slice(thirdDestinationHeadingIndex)
    : undefined;
const pageHeadings =
  kind === 'destinations' && districts.length > 0
    ? [
        ...headings.slice(0, 2),
        {
          depth: 2,
          slug: 'districts-to-explore',
          text:
            locale === 'en' ? 'Districts to explore' : 'Quartiers à explorer',
        },
        ...headings.slice(2),
      ]
    : headings;
const navigationCopy =
  kind === 'itineraries'
    ? {
        label: locale === 'en' ? 'More itineraries' : 'Autres itinéraires',
        previous:
          locale === 'en' ? 'Previous itinerary' : 'Itinéraire précédent',
        next: locale === 'en' ? 'Next itinerary' : 'Itinéraire suivant',
      }
    : {
        label:
          locale === 'en' ? 'Explore another city' : 'Explorer une autre ville',
        previous: locale === 'en' ? 'Previous city' : 'Ville précédente',
        next: locale === 'en' ? 'Next city' : 'Ville suivante',
      };
const itineraryDestinationLinks = Object.entries(destinationPageSlugs).map(
  ([name, slug]) => ({
    name,
    href: withBase(localisedPath(locale, 'destinations', slug)),
  }),
);
---

<ContentLayout
  {locale}
  title={entry.data.title}
  description={entry.data.description}
  {alternatePath}
  lastUpdated={entry.data.lastUpdated}
  headings={pageHeadings}
  heroImage={entry.data.heroImage}
  heroAlt={entry.data.heroAlt}
  heroCaption={entry.data.heroCaption}
  heroClass={kind === 'destinations' ? 'aspect-[5/3]' : 'aspect-[16/7]'}
  {breadcrumbs}
>
  {
    kind === 'itineraries' && 'timeline' in entry.data && (
      <>
        {entry.data.recommendedFor && (
          <InfoBox label={t.labels.recommendedFor}>
            {entry.data.recommendedFor}
          </InfoBox>
        )}
        <h2>{t.labels.route}</h2>
        <DayTimeline
          items={entry.data.timeline}
          dayLabel={t.labels.day}
          destinationLinks={itineraryDestinationLinks}
        />
      </>
    )
  }
  {
    kind === 'destinations' && 'recommendedDuration' in entry.data && (
      <InfoBox
        label={locale === 'en' ? 'Recommended duration' : 'Durée conseillée'}
      >
        {entry.data.recommendedDuration}
      </InfoBox>
    )
  }
  {
    kind === 'destinations' &&
      'personalNote' in entry.data &&
      entry.data.personalNote.length > 0 && (
        <aside
          class="destination-note"
          aria-label={locale === 'en' ? 'My note' : 'Ma note'}
        >
          <p class="destination-note__label">
            {locale === 'en' ? 'My note' : 'Ma note'}
          </p>
          <div class="destination-note__body">
            {entry.data.personalNote.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </aside>
      )
  }
  {
    destinationOpeningHtml && destinationRemainingHtml ? (
      <>
        <Fragment set:html={destinationOpeningHtml} />
        <DistrictGuide {districts} {locale} />
        <Fragment set:html={destinationRemainingHtml} />
      </>
    ) : (
      <>
        <Content />
        {kind === 'destinations' && districts.length > 0 && (
          <DistrictGuide {districts} {locale} />
        )}
      </>
    )
  }
  {
    kind === 'destinations' && (
      <DestinationPhotoGallery
        photos={destinationPhotos}
        destination={entry.data.title}
        {locale}
      />
    )
  }
  {
    entry.data.gallery.length > 0 && (
      <PhotoGallery photos={entry.data.gallery} {locale} />
    )
  }
  {
    kind === 'itineraries' &&
      'transportNotes' in entry.data &&
      entry.data.transportNotes.length > 0 && (
        <>
          <>
            <h2>
              {locale === 'en' ? 'Transport notes' : 'Notes de transport'}
            </h2>
            <ul>
              {entry.data.transportNotes.map((note) => (
                <li>{note}</li>
              ))}
            </ul>
          </>
        </>
      )
  }
  {
    kind === 'itineraries' &&
      'alternatives' in entry.data &&
      entry.data.alternatives.length > 0 && (
        <>
          <>
            <h2>{t.labels.alternatives}</h2>
            <ul>
              {entry.data.alternatives.map((note) => (
                <li>{note}</li>
              ))}
            </ul>
          </>
        </>
      )
  }
  {
    kind === 'itineraries' && (
      <p>
        <a
          class="button-secondary"
          href={
            'mapUrl' in entry.data
              ? (entry.data.mapUrl ?? maps.googleMyMaps)
              : maps.googleMyMaps
          }
        >
          {t.actions.openMap} ↗
        </a>
      </p>
    )
  }
  {
    kind === 'destinations' &&
      districts.length === 0 &&
      'mapUrl' in entry.data &&
      entry.data.mapUrl && (
        <p>
          <a class="button-secondary" href={entry.data.mapUrl}>
            {t.actions.openMap} ↗
          </a>
        </p>
      )
  }
  {
    entry.data.needsReview && (
      <WarningBox label={t.labels.verify}>
        {locale === 'en'
          ? 'Prices, timetables, eligibility and booking conditions can change. Check the official operator or venue before making plans.'
          : 'Les prix, horaires, conditions d’éligibilité et de réservation peuvent évoluer. Vérifiez le site officiel de l’opérateur ou du lieu avant de vous organiser.'}
      </WarningBox>
    )
  }
  {
    (previous || next) && (
      <nav
        class="not-prose mt-14 grid border-y border-ink/15 sm:grid-cols-2"
        aria-label={navigationCopy.label}
      >
        {previous ? (
          <a
            class="group border-b border-ink/15 px-5 py-6 no-underline hover:bg-paper-deep sm:border-b-0 sm:border-r sm:px-7"
            href={withBase(localisedPath(locale, kind, previous.slug))}
          >
            <span class="text-xs font-bold uppercase tracking-[0.14em] text-vermilion-dark">
              ← {navigationCopy.previous}
            </span>
            <span class="mt-2 block font-display text-2xl font-medium text-ink group-hover:underline">
              {previous.title}
            </span>
          </a>
        ) : (
          <span class="hidden sm:block" aria-hidden="true" />
        )}
        {next && (
          <a
            class="group px-5 py-6 text-left no-underline hover:bg-paper-deep sm:px-7 sm:text-right"
            href={withBase(localisedPath(locale, kind, next.slug))}
          >
            <span class="text-xs font-bold uppercase tracking-[0.14em] text-vermilion-dark">
              {navigationCopy.next} →
            </span>
            <span class="mt-2 block font-display text-2xl font-medium text-ink group-hover:underline">
              {next.title}
            </span>
          </a>
        )}
      </nav>
    )
  }
</ContentLayout>
