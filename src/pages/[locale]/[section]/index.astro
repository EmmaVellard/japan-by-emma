---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ItineraryCard from '../../../components/ItineraryCard.astro';
import DestinationCard from '../../../components/DestinationCard.astro';
import tokyoImage from '../../../assets/images/generated/tokyo/tokyo-hero.jpg';
import kyotoImage from '../../../assets/images/generated/kyoto/kyoto-hero.jpg';
import osakaImage from '../../../assets/images/generated/osaka/osaka-hero.jpg';
import {
  dictionaries,
  localisedPath,
  locales,
  otherLocale,
  sectionSlugs,
  type Locale,
  type Section,
} from '../../../i18n/utils';
import { plannedDestinations } from '../../../data/destinations';

type IndexKind = 'guide' | 'itineraries' | 'destinations';
export function getStaticPaths() {
  const kinds: IndexKind[] = ['guide', 'itineraries', 'destinations'];
  return locales.flatMap((locale) =>
    kinds.map((kind) => ({
      params: { locale, section: sectionSlugs[kind][locale] },
      props: { locale, kind },
    })),
  );
}
const { locale, kind } = Astro.props as { locale: Locale; kind: IndexKind };
const t = dictionaries[locale];
const alternatePath = localisedPath(otherLocale(locale), kind as Section);
const page =
  kind === 'guide'
    ? { title: t.pages.guideTitle, intro: t.pages.guideIntro }
    : kind === 'itineraries'
      ? { title: t.pages.itineraryTitle, intro: t.pages.itineraryIntro }
      : { title: t.pages.destinationTitle, intro: t.pages.destinationIntro };
const collection = await getCollection(kind);
const entries = collection
  .filter((entry) => entry.data.locale === locale)
  .sort((a, b) => a.data.order - b.data.order);
const renderedGuides =
  kind === 'guide'
    ? await Promise.all(
        (entries as CollectionEntry<'guide'>[]).map(async (entry) => {
          const { Content } = await render(entry);
          return { entry, Content };
        }),
      )
    : [];
const destinationImages = {
  Tokyo: tokyoImage,
  Kyoto: kyotoImage,
  Osaka: osakaImage,
};
const alt =
  locale === 'en'
    ? 'A personal photograph from my travels in Japan'
    : 'Une photographie personnelle prise pendant mes voyages au Japon';
---

<BaseLayout
  {locale}
  title={page.title}
  description={page.intro}
  {alternatePath}
>
  <header class="section-space shell pb-10">
    <p class="eyebrow">Japan by Emma</p><h1 class="section-title mt-6">
      {page.title}
    </h1><p class="mt-6 max-w-2xl text-lg leading-8 text-ink-soft">
      {page.intro}
    </p>
  </header>
  <section class="shell pb-16">
    {
      kind === 'guide' && (
        <div>
          <div class="journal-note mb-12 grid gap-6 md:grid-cols-[0.45fr_1fr]">
            <p class="eyebrow">
              {locale === 'en' ? 'A note from me' : 'Un mot de ma part'}
            </p>
            <div class="space-y-4 text-lg leading-8">
              <p>
                {locale === 'en' ? (
                  <>
                    After reading several paper guides and watching more travel
                    reels than I can count, I started collecting the places I
                    did not want to forget. This is the version I would send to
                    a friend: <strong>practical notes</strong>, my maps and the
                    small details that make arriving feel easier.
                  </>
                ) : (
                  <>
                    Après avoir lu plusieurs guides papier et regardé plus de
                    vidéos de voyage que je ne pourrais en compter, j’ai
                    commencé à rassembler les lieux que je ne voulais pas
                    oublier. C’est la version que j’enverrais à un proche : des{' '}
                    <strong>notes pratiques</strong>, mes cartes et les petits
                    détails qui rendent l’arrivée plus simple.
                  </>
                )}
              </p>
              <p class="font-display text-2xl italic text-vermilion-dark">
                {locale === 'en'
                  ? 'Enjoy your trip! — Emma'
                  : 'Profitez bien du voyage ! — Emma'}
              </p>
            </div>
          </div>
          <nav
            id="guide-topics"
            class="guide-topic border-y border-ink/15 bg-white/25 py-6"
            aria-label={t.labels.onThisPage}
          >
            <p class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-vermilion-dark">
              {t.labels.onThisPage}
            </p>
            <ol class="grid gap-x-8 gap-y-2 sm:grid-cols-2 lg:grid-cols-3">
              {renderedGuides.map(({ entry }, index) => (
                <li>
                  <a
                    class="group flex gap-3 py-2 font-semibold no-underline"
                    href={`#${entry.data.translationKey}`}
                  >
                    <span class="text-xs text-vermilion-dark">
                      {String(index + 1).padStart(2, '0')}
                    </span>
                    <span class="group-hover:underline">
                      {entry.data.title}
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
          <div class="divide-y divide-ink/15">
            {renderedGuides.map(({ entry, Content }, index) => (
              <article
                id={entry.data.translationKey}
                class="guide-entry guide-topic grid gap-5 py-7 lg:grid-cols-[18rem_minmax(0,46rem)] lg:justify-center lg:gap-8 lg:py-9"
              >
                <div>
                  <p class="text-xs font-bold tracking-[0.15em] text-vermilion-dark">
                    {String(index + 1).padStart(2, '0')}
                  </p>
                  <h2 class="guide-section-title mt-3">{entry.data.title}</h2>
                </div>
                <div class="guide-entry-copy">
                  <p class="text-lg leading-8 text-ink-soft">
                    {entry.data.description}
                  </p>
                  <div class="prose-guide mt-6">
                    <Content />
                  </div>
                  <a
                    class="mt-7 inline-flex text-sm font-bold text-vermilion-dark"
                    href="#guide-topics"
                  >
                    {locale === 'en'
                      ? 'Back to topics ↑'
                      : 'Retour aux thèmes ↑'}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      )
    }
    {
      kind === 'itineraries' && (
        <div class="grid gap-5 lg:grid-cols-2">
          {entries.map(
            (entry, index) =>
              'days' in entry.data && (
                <ItineraryCard
                  title={entry.data.title}
                  description={entry.data.description}
                  href={localisedPath(locale, 'itineraries', entry.data.slug)}
                  days={entry.data.days}
                  dayLabel={t.labels.days}
                  destinations={entry.data.destinations}
                  featured={index === 0}
                />
              ),
          )}
        </div>
      )
    }
    {
      kind === 'destinations' && (
        <>
          <div class="grid gap-5 md:grid-cols-3">
            {entries.map(
              (entry) =>
                'recommendedDuration' in entry.data && (
                  <DestinationCard
                    title={entry.data.title}
                    description={entry.data.description}
                    href={localisedPath(
                      locale,
                      'destinations',
                      entry.data.slug,
                    )}
                    image={
                      destinationImages[
                        entry.data.title as keyof typeof destinationImages
                      ]
                    }
                    {alt}
                    meta={entry.data.recommendedDuration}
                  />
                ),
            )}
          </div>
          <div class="mt-10 border-t border-ink/15 pt-8">
            <>
              <SectionHeader
                title={locale === 'en' ? 'Planned next' : 'À venir'}
                intro={
                  locale === 'en'
                    ? 'More places are already on my list, and I will add them as my notes grow.'
                    : 'D’autres lieux sont déjà sur ma liste et je les ajouterai au fil de mes notes.'
                }
              />
              <ul class="mt-8 flex flex-wrap gap-2">
                {plannedDestinations.map((name) => (
                  <li class="border border-ink/15 bg-white/30 px-4 py-2 text-sm font-semibold">
                    {name}
                  </li>
                ))}
              </ul>
            </>
          </div>
        </>
      )
    }
  </section>
</BaseLayout>
