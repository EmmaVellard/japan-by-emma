---
import '../styles/global.css';
import { withBase } from '../i18n/utils';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Japan by Emma — English / Français</title>
    <meta
      name="description"
      content="Choose English or French to explore my personal Japan travel guide."
    />
    <meta name="robots" content="index,follow" />
  </head>
  <body>
    <main class="grid min-h-screen place-items-center px-4 py-10">
      <section class="editorial-card w-full max-w-4xl overflow-hidden">
        <div class="grid md:grid-cols-[1.1fr_0.9fr]">
          <div class="bg-ink p-8 text-paper sm:p-12">
            <p class="eyebrow text-[#f2a08b]">A personal field guide</p>
            <h1 class="display-title mt-8 !text-[clamp(3.5rem,8vw,6.5rem)]">
              Japan <i class="font-normal text-[#d9846f]">by</i> Emma
            </h1>
            <p class="mt-7 max-w-md leading-7 text-paper/75">
              Practical notes, honest recommendations and flexible itineraries
              for travelling through Japan.
            </p>
          </div>
          <div class="grid content-center gap-4 p-8 sm:p-12">
            <p
              class="text-xs font-bold uppercase tracking-[0.16em] text-ink-soft"
            >
              Choose your language · Choisissez votre langue
            </p>
            <a class="button-primary mt-3" href={withBase('/en/')}>English</a>
            <a class="button-secondary" href={withBase('/fr/')}>Français</a>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
