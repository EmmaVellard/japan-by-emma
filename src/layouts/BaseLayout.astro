---
import '../styles/global.css';
import CloudflareAnalytics from '../components/CloudflareAnalytics.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import { type Locale, withBase } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  alternatePath: string;
  noindex?: boolean;
  schema?: Record<string, unknown>;
}

const {
  locale,
  title,
  description,
  alternatePath,
  noindex = false,
  schema,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const alternate = new URL(withBase(alternatePath), Astro.site);
const pageTitle =
  title === 'Japan by Emma' ? title : `${title} · Japan by Emma`;
const defaultSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  inLanguage: locale,
  url: canonical.toString(),
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f5f0e6" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      hreflang={locale === 'en' ? 'fr' : 'en'}
      href={alternate}
    />
    <link rel="alternate" hreflang={locale} href={canonical} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(withBase('/'), Astro.site)}
    />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'en' ? 'en_GB' : 'fr_FR'} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema ?? defaultSchema)}
    />
  </head>
  <body>
    <a
      class="fixed left-3 top-3 z-[100] -translate-y-24 bg-ink px-4 py-3 text-sm font-bold text-white focus:translate-y-0"
      href="#main-content">Skip to content</a
    >
    <Navbar {locale} {alternatePath} />
    <main id="main-content"><slot /></main>
    <Footer {locale} />
    <CloudflareAnalytics />
  </body>
</html>
