---
interface Props {
  title: string;
  description: string;
  url: string;
  buttonLabel: string;
}
const { title, description, url, buttonLabel } = Astro.props;
---

<article
  class="editorial-card grid min-h-80 content-between bg-[linear-gradient(145deg,#dfe4da,#ebe3d4)] p-7"
>
  <div>
    <p class="eyebrow">Map</p><h3 class="mt-5 text-3xl">{title}</h3><p
      class="mt-3 max-w-md leading-7 text-ink-soft"
    >
      {description}
    </p>
  </div><a
    class="button-primary mt-8 w-fit"
    href={url}
    rel="external noreferrer"
    target="_blank">{buttonLabel} ↗</a
  >
</article>
