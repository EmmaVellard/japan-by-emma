---
import {
  dictionaries,
  localisedPath,
  type Locale,
  withBase,
} from '../i18n/utils';
import BrandName from './BrandName.astro';
interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = dictionaries[locale];
---

<footer class="border-t border-ink/15 bg-ink text-paper">
  <div class="shell grid gap-10 py-14 md:grid-cols-[1fr_auto] md:items-end">
    <div>
      <p class="font-display text-3xl"><BrandName /></p>
      <p class="mt-3 max-w-lg text-sm leading-6 text-paper/70">
        {t.footer.note}<br />{t.footer.source}
      </p>
      <p class="mt-3 max-w-lg text-xs leading-5 text-paper/55">
        {t.footer.copyright}
      </p>
    </div>
    <div class="flex flex-wrap gap-4 text-sm font-semibold">
      <a href={withBase(localisedPath(locale, 'about'))}>{t.nav.about}</a>
      <a href={withBase(localisedPath(locale, 'resources'))}
        >{t.nav.resources}</a
      >
      <a href="https://github.com/emmavellard/japan-by-emma">GitHub</a>
    </div>
  </div>
</footer>
