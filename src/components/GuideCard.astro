---
import { withBase } from '../i18n/utils';
interface Props {
  title: string;
  description: string;
  href: string;
  number?: string;
  meta?: string;
}
const { title, description, href, number, meta } = Astro.props;
---

<a
  class="editorial-card group flex min-h-64 flex-col justify-between p-6 no-underline transition-transform hover:-translate-y-1 sm:p-7"
  href={withBase(href)}
>
  <div class="flex items-start justify-between gap-6">
    <span
      class="text-xs font-bold uppercase tracking-[0.15em] text-vermilion-dark"
      >{number ?? meta}</span
    ><span
      aria-hidden="true"
      class="text-xl transition-transform group-hover:translate-x-1">↗</span
    >
  </div>
  <div>
    <h3 class="text-2xl leading-tight">{title}</h3><p
      class="mt-3 text-sm leading-6 text-ink-soft"
    >
      {description}
    </p>
  </div>
</a>
