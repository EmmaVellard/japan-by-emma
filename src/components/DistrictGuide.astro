---
import PersonalRecommendationBadge from './PersonalRecommendationBadge.astro';
import ResearchRecommendationBadge from './ResearchRecommendationBadge.astro';
import type { CityDistrict } from '../data/city-districts';
import { districtMapLinks } from '../data/city-districts';

interface Props {
  districts: CityDistrict[];
  locale: 'en' | 'fr';
}

const { districts, locale } = Astro.props;
const escapeRegExp = (value: string) =>
  value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
const highlightedDescriptions = districts.map(
  ({ description, descriptionHighlights = [] }) => {
    const splitAt = description.search(/[,;:]/);
    const lead = splitAt > 0 ? description.slice(0, splitAt) : description;
    const highlights = [lead, ...descriptionHighlights];
    const expression = new RegExp(
      `(${highlights
        .sort((a, b) => b.length - a.length)
        .map(escapeRegExp)
        .join('|')})`,
      'g',
    );

    return description
      .split(expression)
      .filter(Boolean)
      .map((text) => ({ text, highlighted: highlights.includes(text) }));
  },
);
const copy =
  locale === 'en'
    ? {
        title: 'Districts to explore',
        intro:
          'Exploring one area at a time keeps the day calmer. Each district brings together a few essential sights and useful places for food or a pause.',
        mapstr: 'Personally tried · Mapstr',
        google: 'Saved for research · Google Maps',
        points: 'Points of interest',
        mapstrAction: 'Open my Mapstr',
        googleAction: 'Open my Google map',
      }
    : {
        title: 'Quartiers à explorer',
        intro:
          'Explorer une zone à la fois rend la journée plus douce. Chaque quartier réunit quelques lieux essentiels et des adresses utiles pour manger ou faire une pause.',
        mapstr: 'Testé personnellement · Mapstr',
        google: 'Enregistré pour mes recherches · Google Maps',
        points: 'Points d’intérêt',
        mapstrAction: 'Ouvrir mon Mapstr',
        googleAction: 'Ouvrir ma carte Google',
      };
---

<section class="district-guide not-prose">
  <div class="max-w-2xl">
    <h2
      id="districts-to-explore"
      class="scroll-mt-28 font-display text-[clamp(1.9rem,3.4vw,2.75rem)] font-medium leading-[1.05] text-ink"
    >
      {copy.title}
    </h2>
    <p class="mt-4 text-base leading-7 text-ink-soft">{copy.intro}</p>
  </div>

  <div class="mt-7 divide-y divide-ink/15 border-y border-ink/15">
    {
      districts.map((district, index) => (
        <article class="grid gap-5 py-7 md:grid-cols-[minmax(0,14rem)_minmax(0,1fr)] md:gap-7">
          <div class="min-w-0">
            <span class="text-xs font-bold tabular-nums tracking-[0.16em] text-vermilion-dark">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h2 class="mt-2 break-words font-display text-[1.55rem] font-medium leading-tight text-ink">
              {district.name}
            </h2>
          </div>
          <div class="min-w-0">
            <p class="max-w-2xl leading-7 text-ink-soft">
              {highlightedDescriptions[index]?.map((part) =>
                part.highlighted ? <strong>{part.text}</strong> : part.text,
              )}
            </p>
            <div class="mt-4">
              <p class="text-xs font-bold uppercase tracking-[0.12em] text-vermilion-dark">
                {copy.points}
              </p>
              <ul class="mt-2 grid gap-1.5">
                {district.pointsOfInterest.map((point) => (
                  <li class="grid grid-cols-[1rem_minmax(0,1fr)] items-start text-sm font-semibold leading-6 text-ink">
                    <span aria-hidden="true" class="text-vermilion">
                      —
                    </span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>
            {district.recommendations.length > 0 && (
              <div class="mt-5 grid gap-3">
                {district.recommendations.map((place) => (
                  <div class="border-l-2 border-vermilion/60 bg-white/25 px-4 py-4">
                    {place.source === 'mapstr' ? (
                      <PersonalRecommendationBadge label={copy.mapstr} />
                    ) : (
                      <ResearchRecommendationBadge label={copy.google} />
                    )}
                    <h3 class="mt-3 font-display text-xl font-medium text-ink">
                      {place.name}
                    </h3>
                    <p class="mt-1 text-xs font-bold uppercase tracking-[0.1em] text-vermilion-dark">
                      {place.category}
                    </p>
                    <p class="mt-2 text-sm leading-6 text-ink-soft">
                      {place.note}
                    </p>
                  </div>
                ))}
              </div>
            )}
          </div>
        </article>
      ))
    }
  </div>

  <div class="mt-6 grid gap-3 sm:grid-cols-2">
    <a
      class="button-primary w-full text-center"
      href={districtMapLinks.mapstr}
      target="_blank"
      rel="noreferrer"
    >
      {copy.mapstrAction} ↗
    </a>
    <a
      class="button-secondary w-full text-center"
      href={districtMapLinks.googleMyMaps}
      target="_blank"
      rel="noreferrer"
    >
      {copy.googleAction} ↗
    </a>
  </div>
</section>
