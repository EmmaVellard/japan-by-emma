---
import type { ImageMetadata } from 'astro';
import { withBase } from '../i18n/utils';
import HeroImage from './HeroImage.astro';
interface Props {
  title: string;
  description: string;
  href: string;
  image?: ImageMetadata;
  alt?: string;
  meta?: string;
}
const { title, description, href, image, alt, meta } = Astro.props;
---

<a
  class="editorial-card group block no-underline transition-transform hover:-translate-y-1"
  href={withBase(href)}
>
  <HeroImage {image} {alt} class="aspect-[4/3]" />
  <div class="p-5">
    <div class="flex items-baseline justify-between gap-4">
      <h3 class="text-2xl">{title}</h3><span
        aria-hidden="true"
        class="transition-transform group-hover:translate-x-1">→</span
      >
    </div><p class="mt-2 text-sm leading-6 text-ink-soft">{description}</p>{
      meta && (
        <p class="mt-4 text-xs font-bold uppercase tracking-wider text-vermilion-dark">
          {meta}
        </p>
      )
    }
  </div>
</a>
