---
interface Props {
  title: string;
  text: string;
  meta?: string;
}
const { title, text, meta } = Astro.props;
---

<article class="editorial-card p-6">
  {
    meta && (
      <p class="text-xs font-bold uppercase tracking-wider text-vermilion-dark">
        {meta}
      </p>
    )
  }<h3 class="mt-3 text-2xl">{title}</h3><p
    class="mt-3 text-sm leading-6 text-ink-soft"
  >
    {text}
  </p>
</article>
