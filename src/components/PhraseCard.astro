---
interface Props {
  phrase: string;
  meaning: string;
  japanese?: string;
}
const { phrase, meaning, japanese } = Astro.props;
---

<article class="border border-ink/10 bg-white/35 p-5">
  <p class="font-display text-2xl">{japanese ?? phrase}</p>{
    japanese && <p class="mt-1 font-semibold">{phrase}</p>
  }<p class="mt-3 text-sm text-ink-soft">{meaning}</p>
</article>
