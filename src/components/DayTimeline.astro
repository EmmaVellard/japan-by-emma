---
interface Item {
  day: string;
  title: string;
  note?: string | undefined;
}
interface DestinationLink {
  name: string;
  href: string;
}
interface Props {
  items: Item[];
  dayLabel: string;
  destinationLinks?: DestinationLink[];
}
const { items, dayLabel, destinationLinks = [] } = Astro.props;
const escapedDestinationNames = destinationLinks
  .map(({ name }) => name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'))
  .sort((first, second) => second.length - first.length);
const destinationPattern =
  escapedDestinationNames.length > 0
    ? new RegExp(`(${escapedDestinationNames.join('|')})`, 'gi')
    : undefined;

function titleParts(title: string) {
  return destinationPattern ? title.split(destinationPattern) : [title];
}

function destinationFor(part: string) {
  return destinationLinks.find(
    ({ name }) => name.toLocaleLowerCase() === part.toLocaleLowerCase(),
  );
}
---

<ol class="mt-8 border-y border-ink/15">
  {
    items.map((item, index) => (
      <li class="grid grid-cols-[5.25rem_minmax(0,1fr)] border-b border-ink/10 last:border-b-0 sm:grid-cols-[7rem_minmax(0,1fr)]">
        <div class="flex flex-col justify-center border-r border-ink/10 bg-paper-deep/70 px-3 py-5 sm:px-5">
          <span class="text-[0.65rem] font-bold uppercase tracking-[0.14em] text-vermilion-dark">
            {dayLabel}
          </span>
          <span class="mt-1 font-display text-2xl font-medium leading-none sm:text-3xl">
            {item.day}
          </span>
        </div>
        <div class="grid gap-2 px-5 py-5 sm:grid-cols-[2.4rem_minmax(0,1fr)] sm:px-7 sm:py-6">
          <span class="hidden pt-1 text-xs font-bold tracking-[0.14em] text-ink-soft sm:block">
            {String(index + 1).padStart(2, '0')}
          </span>
          <div>
            <h3 class="text-xl sm:text-2xl">
              {titleParts(item.title).map((part) => {
                const destination = destinationFor(part);
                return destination ? (
                  <a
                    href={destination.href}
                    class="decoration-vermilion/35 underline-offset-4 hover:decoration-vermilion-dark"
                  >
                    {part}
                  </a>
                ) : (
                  part
                );
              })}
            </h3>
            {item.note && (
              <p class="mt-2 text-sm leading-6 text-ink-soft">
                {titleParts(item.note).map((part) => {
                  const destination = destinationFor(part);
                  return destination ? (
                    <a
                      href={destination.href}
                      class="decoration-vermilion/35 underline-offset-4 hover:decoration-vermilion-dark"
                    >
                      {part}
                    </a>
                  ) : (
                    part
                  );
                })}
              </p>
            )}
          </div>
        </div>
      </li>
    ))
  }
</ol>
