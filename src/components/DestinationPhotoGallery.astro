---
import type { ImageMetadata } from 'astro';
import ResponsivePhoto from './ResponsivePhoto.astro';
import PhotographyCredit from './PhotographyCredit.astro';

interface Props {
  photos: ImageMetadata[];
  destination: string;
  locale: 'en' | 'fr';
}

const { photos, destination, locale } = Astro.props;
const title =
  locale === 'en' ? `${destination}, in pictures` : `${destination}, en images`;
const placeholder =
  locale === 'en'
    ? 'Personal photograph coming soon'
    : 'Photographie personnelle à venir';
const alt =
  locale === 'en'
    ? `A personal photograph of ${destination}`
    : `Une photographie personnelle de ${destination}`;
const displayPhotos = photos.slice(0, 6);
---

<section class="not-prose mt-10 border-t border-ink/15 pt-9">
  <p class="eyebrow">{title}</p>
  {
    displayPhotos.length > 0 ? (
      <>
        <div class="mt-6 grid grid-cols-1 gap-2 sm:grid-cols-2">
          {displayPhotos.map((image) => (
            <div class="relative aspect-square overflow-hidden bg-sage-pale">
              <ResponsivePhoto
                {image}
                {alt}
                class="h-full"
                sizes="(min-width: 64rem) 23rem, (min-width: 40rem) 50vw, 100vw"
              />
              <button
                type="button"
                class="lens-enlarge-button"
                data-city-photo-src={image.src}
                data-city-photo-alt={alt}
                aria-label={
                  locale === 'en'
                    ? 'Open this photograph larger'
                    : 'Agrandir cette photographie'
                }
              />
            </div>
          ))}
        </div>
        <PhotographyCredit class="mt-3 text-right" />
        <dialog
          class="lens-lightbox"
          data-city-photo-lightbox
          aria-label={
            locale === 'en' ? 'Enlarged photograph' : 'Photographie agrandie'
          }
        >
          <button
            type="button"
            class="lens-lightbox-close"
            data-city-photo-close
            aria-label={
              locale === 'en' ? 'Close photograph' : 'Fermer la photographie'
            }
          >
            ×
          </button>
          <button
            type="button"
            class="lens-lightbox-nav lens-lightbox-previous"
            data-city-photo-previous
            aria-label={
              locale === 'en'
                ? 'Previous photograph'
                : 'Photographie précédente'
            }
          >
            ‹
          </button>
          <img data-city-photo-lightbox-image src="" alt="" />
          <button
            type="button"
            class="lens-lightbox-nav lens-lightbox-next"
            data-city-photo-next
            aria-label={
              locale === 'en' ? 'Next photograph' : 'Photographie suivante'
            }
          >
            ›
          </button>
        </dialog>
      </>
    ) : (
      <div class="mt-6 grid grid-cols-2 gap-2 sm:grid-cols-3">
        <div class="col-span-2 grid min-h-64 place-items-center bg-[linear-gradient(140deg,#dfe4da,#d2c8b7)] p-6 text-center text-xs font-bold uppercase tracking-[0.16em] text-ink/55 sm:min-h-80">
          {placeholder}
        </div>
        <div class="grid min-h-40 place-items-center bg-[linear-gradient(155deg,#ebe3d4,#dfe4da)] p-5 text-center text-xs font-bold uppercase tracking-[0.16em] text-ink/45">
          {placeholder}
        </div>
        <div class="grid min-h-40 place-items-center bg-[linear-gradient(125deg,#d2c8b7,#ebe3d4)] p-5 text-center text-xs font-bold uppercase tracking-[0.16em] text-ink/45 sm:col-start-3">
          {placeholder}
        </div>
      </div>
    )
  }
</section>

<script>
  const cityPhotoLightbox = document.querySelector<HTMLDialogElement>(
    '[data-city-photo-lightbox]',
  );
  const cityPhotoLightboxImage =
    cityPhotoLightbox?.querySelector<HTMLImageElement>(
      '[data-city-photo-lightbox-image]',
    );
  const cityPhotoButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-city-photo-src]'),
  );
  let activeCityPhotoIndex = 0;

  const showCityPhoto = (index: number) => {
    if (!cityPhotoLightboxImage || cityPhotoButtons.length === 0) return;
    activeCityPhotoIndex =
      (index + cityPhotoButtons.length) % cityPhotoButtons.length;
    const button = cityPhotoButtons[activeCityPhotoIndex];
    if (!button) return;
    cityPhotoLightboxImage.src = button.dataset.cityPhotoSrc ?? '';
    cityPhotoLightboxImage.alt = button.dataset.cityPhotoAlt ?? '';
  };

  cityPhotoButtons.forEach((button, index) => {
    button.addEventListener('click', () => {
      if (!cityPhotoLightbox) return;
      showCityPhoto(index);
      cityPhotoLightbox.showModal();
    });
  });

  cityPhotoLightbox
    ?.querySelector('[data-city-photo-previous]')
    ?.addEventListener('click', () => showCityPhoto(activeCityPhotoIndex - 1));

  cityPhotoLightbox
    ?.querySelector('[data-city-photo-next]')
    ?.addEventListener('click', () => showCityPhoto(activeCityPhotoIndex + 1));

  cityPhotoLightbox
    ?.querySelector('[data-city-photo-close]')
    ?.addEventListener('click', () => cityPhotoLightbox.close());

  cityPhotoLightbox?.addEventListener('click', (event) => {
    if (event.target === cityPhotoLightbox) cityPhotoLightbox.close();
  });

  cityPhotoLightbox?.addEventListener('keydown', (event) => {
    if (event.key === 'ArrowLeft') showCityPhoto(activeCityPhotoIndex - 1);
    if (event.key === 'ArrowRight') showCityPhoto(activeCityPhotoIndex + 1);
  });
</script>
